# HRDK Pen Server — Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB (optional — app works without it)
MONGO_URI=mongodb://127.0.0.1:27017/hrdkpen

# Note: API key is NOT stored here.
# Users provide their own OpenAI key in the app, which is sent to this server
# and forwarded to OpenAI. The key is never stored server-side.
